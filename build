#!/usr/bin/env bash

set -euo pipefail

FILES=()
ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --files)
            shift
            while [[ $# -gt 0 && "$1" != --* ]]; do
                FILES+=("$1")
                shift
            done
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

if [[ ${#FILES[@]} -gt 0 ]]; then
    FILES_STR="${FILES[*]}"
    echo "  Embedding: $FILES_STR"
    exec make "${ARGS[@]}" EXTRA_FILES="$FILES_STR"
else
    exec make "${ARGS[@]}"
fi
